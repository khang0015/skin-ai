# Copy this file to .env on the server, then edit the values.

# API and app
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_UPLOAD_SIZE_MB=10
ADMIN_TOKEN=change-this-local-admin-token
ADMIN_PAGE_PASSWORD=change-this-admin-password

# PostgreSQL used by docker-compose.prod.yml
POSTGRES_USER=skin_ai_user
POSTGRES_PASSWORD=change_this_database_password
POSTGRES_DB=skin_ai

# The app container uses postgres service name as host.
DATABASE_URL=postgresql+psycopg://skin_ai_user:change_this_database_password@postgres:5432/skin_ai

# OpenAI GPT Vision Classifier and RAG Generator
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini

# Semantic RAG retrieval
KNOWLEDGE_BASE_PATH=backend/app/data/knowledge_base.md
RAG_DOCS_DIR=/app/backend/app/data/docs/raw
RAG_VECTOR_STORE_PATH=/app/backend/app/data/vector_store
RAG_COLLECTION_NAME=skin_lesion_knowledge
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_CACHE_DIR=/app/backend/models/embeddings
RAG_TOP_K=4
RAG_RELEVANCE_THRESHOLD=0.30
RAG_MMR_LAMBDA=0.6

# ML pipeline
MODEL_REGISTRY_PATH=backend/app/data/model_registry.json
DETECTION_CONFIDENCE_THRESHOLD=0.25
SKIN_THRESHOLD=0.15
UPLOAD_CLEANUP_DAYS=7
API_CALL_TIMEOUT=60

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# HuggingFace classifier, if used
HUGGING_FACE_API_KEY=your-huggingface-api-key-here
HF_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Ollama/Qwen. Use host.docker.internal if the SSH tunnel runs on the host.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=300
RAG_LLM_BACKEND=auto
