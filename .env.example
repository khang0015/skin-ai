# Model registry
MODEL_REGISTRY_PATH=backend/app/data/model_registry.json

# API and app
APP_HOST=0.0.0.0
APP_PORT=8000
MAX_UPLOAD_SIZE_MB=10
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/skin_ai
ADMIN_TOKEN=change-this-local-admin-token
ADMIN_PAGE_PASSWORD=12345

# OpenAI GPT Vision Classifier and RAG Generator
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini

# Semantic RAG retrieval
KNOWLEDGE_BASE_PATH=backend/app/data/knowledge_base.md
RAG_DOCS_DIR=backend/app/data/docs/raw
RAG_VECTOR_STORE_PATH=backend/app/data/vector_store
RAG_COLLECTION_NAME=skin_lesion_knowledge
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAG_EMBEDDING_DEVICE=cpu
RAG_EMBEDDING_CACHE_DIR=backend/models/embeddings
RAG_TOP_K=4
# Minimum cosine similarity (0.0–1.0) for a chunk to be included; below this = "not relevant"
RAG_RELEVANCE_THRESHOLD=0.30
# MMR diversity lambda: 1.0 = pure relevance, 0.0 = pure diversity
RAG_MMR_LAMBDA=0.6

# ML pipeline
# Minimum YOLO detection confidence (0.0–1.0) to pass to classifier
DETECTION_CONFIDENCE_THRESHOLD=0.25
# Skin detection threshold (fraction of skin pixels required)
SKIN_THRESHOLD=0.15

# Upload management
# Delete uploaded images older than this many days (0 = disabled)
UPLOAD_CLEANUP_DAYS=7

# External API timeout in seconds
API_CALL_TIMEOUT=60

# Database connection pool (PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# HuggingFace Phi-4 Vision Classifier
HUGGING_FACE_API_KEY=your-huggingface-api-key-here
HF_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# ── Ollama RAG LLM (Qwen on Azure VM via SSH tunnel) ─────────────────
# Step 1: Open SSH tunnel on your local machine:
#   ssh -i Khang_key.pem -N -L 11434:localhost:11434 azureuser@20.244.6.94
# Step 2: Set these env vars:
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=300
# RAG LLM backend: "ollama" | "openai" | "auto"
# "auto" = use Ollama if reachable, else fall back to OpenAI
RAG_LLM_BACKEND=auto
